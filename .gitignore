# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
!.env.example

# 소개 자료 (대용량 바이너리 — 리포에 넣지 않고 로컬/별도 보관)
/페이지-소개서/

# 에이전트 작업 폴더 — 마케팅 컨텍스트 문서만 추적, 나머지(로컬 캐시·시크릿)는 무시
